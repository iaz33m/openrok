{
  "name": "@openrock/desktop-client",
  "version": "0.1.0",
  "private": true,
  "description": "OpenRock always-on desktop TCP tunnel client.",
  "author": "OpenRock",
  "type": "module",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && tsc -p tsconfig.renderer.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "start": "npm run build && electron .",
    "package:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@openrock/agent": "0.1.0",
    "@openrock/shared": "0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "42.4.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2"
  },
  "build": {
    "appId": "com.openrock.client",
    "productName": "OpenRock Client",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

# Server-specific defaults for 44.193.192.39 on Amazon Linux 2023.
# Copy to /opt/openrock/.env on the EC2 host and replace both token values.
OPENROCK_PUBLIC_HOST=44.193.192.39
OPENROCK_HTTP_HOST=0.0.0.0
OPENROCK_HTTP_PORT=8080
OPENROCK_TCP_BIND_HOST=0.0.0.0
OPENROCK_TCP_PORT_RANGE=40000-40100

# Generate strong values:
# openssl rand -hex 32
OPENROCK_AGENT_TOKEN=replace-with-strong-agent-token
OPENROCK_ADMIN_TOKEN=replace-with-strong-admin-token
